{
  "name": "dca-community-events",
  "version": "0.1.0",
  "description": "Community events platform for digital infrastructure professionals",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
  "dev": "node --watch src/index.js",
  "build": "cd frontend && npm install && npm run build && cd .. && node src/scripts/ingest-events.js && echo 'Build complete'",
  "start": "node src/index.js",
  "db:generate": "drizzle-kit generate",
  "db:migrate": "node src/db/migrate.js",
  "db:studio": "drizzle-kit studio",
  "seed": "node src/db/seed.js"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.0",
    "dotenv": "^16.3.1",
    "drizzle-kit": "^0.20.14",
    "drizzle-orm": "^0.30.10",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "postgres": "^3.4.9",
    "resend": "^3.0.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.6"
  },
  "engines": {
    "node": "20.x"
  }
}
