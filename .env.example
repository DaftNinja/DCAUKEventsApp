# =============================================================================
# DCA Community Events — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# NEVER commit .env to git — it contains secrets. (.env is gitignored.)
# On Railway, set these in the service's Variables tab instead of using a file.
# =============================================================================

# ---- Database ----------------------------------------------------------------
# Local Docker Compose uses the bundled Postgres (see docker-compose.yml).
# On Railway this is auto-populated when you add a PostgreSQL plugin.
DATABASE_URL=postgresql://community:community@localhost:5432/community

# ---- LinkedIn OAuth ----------------------------------------------------------
# From https://www.linkedin.com/developers/apps (Auth tab).
# The redirect URI must EXACTLY match one registered in your LinkedIn app.
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here
LINKEDIN_REDIRECT_URI=http://localhost:8080/api/auth/linkedin/callback

# ---- JWT ---------------------------------------------------------------------
# Used to sign session tokens. Use a long random string in production, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret

# ---- Resend (email) ----------------------------------------------------------
# From https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# ---- App / runtime -----------------------------------------------------------
NODE_ENV=development

# Port Express listens on. Railway injects its own PORT at runtime;
# the Docker image defaults to 8080 if unset.
PORT=8080

# Public URLs used for CORS and OAuth redirects.
# Locally these point at the single combined deployment (Express serves React).
# On Railway, set both to your service URL (e.g. https://your-app.railway.app),
# and later to https://community.1giglabs.com after the domain is configured.
FRONTEND_URL=http://localhost:8080
BACKEND_URL=http://localhost:8080
